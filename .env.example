# Environnement applicatif
APP_ENV=prod

# Base MySQL du portail
DB_HOST=localhost
DB_PORT=3306
DB_NAME=portal_db
DB_USER=portal_user
DB_PASS=change_me

# Cookies de session
COOKIE_SECURE=1
COOKIE_SAMESITE=Lax

# Secret de signature pour liens temporaires publics
SHARE_TOKEN_SECRET=change_me_with_a_long_random_value

